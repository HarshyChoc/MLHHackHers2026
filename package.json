{
  "name": "goal-coach-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @goalcoach/api",
    "dev:web": "npm run dev -w @goalcoach/web",
    "dev:worker": "npm run dev -w @goalcoach/worker",
    "typecheck": "npm run typecheck -ws --if-present",
    "build": "npm run build -ws --if-present"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
